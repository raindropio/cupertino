    ".\n\nYou'll still be able to take advantage of PRO plan through this date, but you will not be charged a subscription fee moving forward." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\ndu können den PRO-Plan bis zu diesem Datum nutzen, aber es werden keine weiteren Gebühren erhoben."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\nPodrás aprovechar el plan PRO hasta esta fecha, pero no se te cobrará la suscripción en adelante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\nVous pourrez profiter du plan PRO jusqu'à cette date, mais vous ne serez plus facturé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\nPotrai ancora usufruire del piano PRO fino a questa data, ma non ti verrà addebitata la quota di abbonamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "まで有効です。\n\nこの日付までPROプランを利用できますが、今後サブスクリプション料金は請求されません。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\nJe kunt het PRO-plan tot deze datum gebruiken, maar er worden geen kosten meer in rekening gebracht."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\nNadal możesz korzystać z planu PRO do tej daty, ale nie będziesz już obciążany opłatą."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\nVocê ainda poderá aproveitar o plano PRO até esta data, mas não será mais cobrado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ".\n\nВы сможете пользоваться планом PRO до этой даты, но плата за подписку больше взиматься не будет."
          }
        }
      }
    },
