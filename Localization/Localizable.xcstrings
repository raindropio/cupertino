    " - Permanent copies become inaccessible and could be removed in future\n" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Permanente Kopien werden unzugänglich und können in Zukunft entfernt werden\n"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Las copias permanentes serán inaccesibles y podrían eliminarse en el futuro\n"
