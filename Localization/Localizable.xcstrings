    "Share this link with the person you want to invite to the collection.\n\nPlease note, this link can only be used once and will expire in a week." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teilen du diesen Link mit der Person, die du zur Sammlung einladen möchten.\n\nBitte beachten Sie, dieser Link kann nur einmal verwendet werden und läuft nach einer Woche ab."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comparte este enlace con la persona que deseas invitar a la colección.\n\nTen en cuenta que este enlace solo se puede usar una vez y caducará en una semana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partagez ce lien avec la personne que vous souhaitez inviter dans la collection.\n\nVeuillez noter que ce lien ne peut être utilisé qu'une seule fois et expirera dans une semaine."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Condividi questo link con la persona che vuoi invitare nella collezione.\n\nNota: questo link può essere usato solo una volta e scadrà tra una settimana."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コレクションに招待したい人にこのリンクを共有してください。\n\nこのリンクは1回のみ使用可能で、1週間後に期限切れになります。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deel deze link met de persoon die je wilt uitnodigen voor de collectie.\n\nLet op: deze link kan slechts één keer worden gebruikt en verloopt na een week."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Udostępnij ten link osobie, którą chcesz zaprosić do kolekcji.\n\nPamiętaj, ten link może być użyty tylko raz i wygaśnie za tydzień."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compartilhe este link com a pessoa que deseja convidar para a coleção.\n\nObserve que este link só pode ser usado uma vez e expirará em uma semana."
