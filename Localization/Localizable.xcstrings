{
  "sourceLanguage" : "en",
  "strings" : {
    "" : {
      "shouldTranslate" : false
    },
    "\nAuto-renewable. You will get access to all features in all supported platforms.\n\n" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nAutomatisch verlängerbar. du erhalten Zugriff auf alle Funktionen auf allen unterstützten Plattformen.\n\n"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nRenovación automática. Tendrás acceso a todas las funciones en todas las plataformas compatibles.\n\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nRenouvellement automatique. Vous aurez accès à toutes les fonctionnalités sur toutes les plateformes.\n\n"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nRinnovo automatico. Avrai accesso a tutte le funzionalità su tutte le piattaforme supportate.\n\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n自動更新。すべてのサポートされているプラットフォームで全機能にアクセスできます。\n\n"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nAutomatisch verlengend. Je krijgt toegang tot alle functies op alle ondersteunde platformen.\n\n"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nOdnawiana automatycznie. Uzyskasz dostęp do wszystkich funkcji na wszystkich wspieranych platformach.\n\n"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nRenovação automática. Você terá acesso a todos os recursos em todas as plataformas suportadas.\n\n"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nАвтоматическое продление. Вы получите доступ ко всем функциям на всех поддерживаемых платформах.\n\n"
          }
        }
      }
    },
    " - Cloud backup will be stopped\n" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Cloud-Backup wird gestoppt\n"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Se detendrá la copia de seguridad en la nube\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - La sauvegarde cloud sera arrêtée\n"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Il backup cloud verrà interrotto\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - クラウドバックアップが停止されます\n"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Cloudback-up wordt gestopt\n"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Kopia zapasowa w chmurze zostanie zatrzymana\n"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - O backup na nuvem será interrompido\n"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " - Облачный бэкап будет остановлен\n"
          }
        }
      }
    },
