          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trabaja en colecciones de forma privada con colegas, amigos y familiares. [Más información](https://help.raindrop.io/collaboration/)"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Travaillez ensemble sur des collections en privé avec vos collègues, amis et famille. [En savoir plus](https://help.raindrop.io/collaboration/)"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lavora insieme sulle collezioni in privato con colleghi, amici e familiari. [Scopri di più](https://help.raindrop.io/collaboration/)"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同僚、友人、家族とプライベートにコレクションで共同作業。[詳しく見る](https://help.raindrop.io/collaboration/)"
