    "We attempted to charge the card you have on file but were unable to do so.\n\nWe will automatically attempt to charge your card again within 24-48 hours." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir haben versucht, deine hinterlegte Karte zu belasten, konnten dies jedoch nicht.\n\nWir werden innerhalb von 24-48 Stunden automatisch erneut versuchen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intentamos cobrar la tarjeta que tienes registrada pero no pudimos.\n\nIntentaremos cobrar tu tarjeta automáticamente en 24-48 horas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous avons tenté de débiter la carte enregistrée mais sans succès.\n\nNous réessaierons automatiquement dans 24 à 48 heures."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abbiamo tentato di addebitare la carta in archivio ma non ci siamo riusciti.\n\nRitenteremo automaticamente entro 24-48 ore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "登録されたカードへの請求を試みましたが、できませんでした。\n\n24〜48時間以内に自動的に再度請求を試みます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We hebben geprobeerd je geregistreerde kaart te belasten maar dat is niet gelukt.\n\nWe proberen het automatisch opnieuw binnen 24-48 uur."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Próbowaliśmy obciążyć kartę, ale nie udało się.\n\nAutomatycznie ponowimy próbę w ciągu 24-48 godzin."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tentamos cobrar o cartão registrado mas não conseguimos.\n\nTentaremos automaticamente novamente em 24-48 horas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мы попытались списать средства с вашей карты, но не смогли.\n\nМы автоматически повторим попытку в течение 24-48 часов."
          }
        }
      }
    },
    "We keep your [data safe](https://help.raindrop.io/security), never sold.\nNo limits. Starting from $0." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir bewahren deine [Daten sicher](https://help.raindrop.io/security) auf, niemals verkauft.\nKeine Limits. Ab 0 $."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenemos tus [datos seguros](https://help.raindrop.io/security), nunca vendidos.\nSin límites. Desde $0."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous gardons vos [données en sécurité](https://help.raindrop.io/security), jamais vendues.\nSans limites. À partir de 0 $."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tuoi [dati sono al sicuro](https://help.raindrop.io/security), mai venduti.\nSenza limiti. A partire da 0 $."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの[データは安全](https://help.raindrop.io/security)に保護され、販売されることはありません。\n制限 なし。$0から。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We houden je [gegevens veilig](https://help.raindrop.io/security), nooit verkocht.\nGeen limieten. Vanaf $0."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wasze [dane są bezpieczne](https://help.raindrop.io/security), nigdy nie sprzedawane.\nBez limitów. Od 0 $."
