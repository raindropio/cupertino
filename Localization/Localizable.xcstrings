          }
        }
      }
    },
    "Yes! We offer either monthly or yearly billing options. The yearly billing option is always cheaper (usually ~%@ discount)." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja! Wir bieten sowohl monatliche als auch jährliche Abrechnungsoptionen. Die jährliche Option ist immer günstiger (ca. %@ Rabatt)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Sí! Ofrecemos opciones de facturación mensual o anual. La opción anual siempre es más económica (normalmente ~%@ de descuento)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oui ! Nous proposons des options mensuelles ou annuelles. L'option annuelle est toujours moins chère (environ %@ de réduction)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sì! Offriamo opzioni mensili o annuali. L'opzione annuale è sempre più conveniente (sconto di circa il %@)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "はい！月額と年額の請求オプションがあります。年額オプションは常にお得です（通常約%@割引）。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja! We bieden zowel maandelijkse als jaarlijkse factureringsopties. De jaarlijkse optie is altijd goedkoper (meestal ~%@ korting)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tak! Oferujemy opcje rozliczeń miesięcznych lub rocznych. Opcja roczna jest zawsze tańsza (zwykle ~%@ zniżki)."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sim! Oferecemos opções de cobrança mensal ou anual. A opção anual é sempre mais barata (geralmente ~%@ de desconto)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да! Мы предлагаем ежемесячную и годовую оплату. Годовая всегда дешевле (обычно скидка ~%@)."
          }
        }
      }
    },
    "You can use it on unlimited devices and create unlimited items and collections in all plans." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "du können es auf unbegrenzten Geräten nutzen und unbegrenzt Elemente und Sammlungen in allen Plänen erstellen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes usarlo en dispositivos ilimitados y crear elementos y colecciones ilimitadas en todos los planes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez l'utiliser sur des appareils illimités et créer des éléments et collections illimités dans tous les plans."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi usarlo su dispositivi illimitati e creare elementi e collezioni illimitati in tutti i piani."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのプランで、無制限のデバイスで使用し、無制限のアイテムとコレクションを作成できます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt het op onbeperkte apparaten gebruiken en onbeperkte items en collecties maken in alle plannen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz używać go na nieograniczonej liczbie urządzeń i tworzyć nieograniczoną liczbę elementów i kolekcji we wszystkich planach."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você pode usá-lo em dispositivos ilimitados e criar itens e coleções ilimitados em todos os planos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все планы включают безлимитные устройства, элементы и коллекции."
          }
        }
      }
    },
